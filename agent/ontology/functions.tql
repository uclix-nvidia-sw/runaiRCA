# Run:AI RCA ontology — TypeDB 3.x reasoning FUNCTIONS.
#
# TypeDB 3.0 replaced 2.x `rule ... when {} then {}` reasoning with FUNCTIONS
# (`define fun`): query-time derivation, invoked explicitly from a match with
# `let $x in fn(...)`. These give the knowledge graph real reasoning power
# (what the earlier PoC deferred as "complex").
#
# Loaded AFTER the schema by ontology/load_functions.py — as a SEPARATE define so
# a function issue on a future TypeDB patch can never break the core schema/data
# load. VALIDATED against TypeDB CE 3.11.5 (HTTP /v1/query) on 2026-07-02:
#   fixes_for_xid(79)                    -> "Reset the GPU / contact support."
#   xids_for_gpu_model("H100")           -> 79
#   fixes_for_family("gpu_hardware_error") -> "Reset the GPU / contact support."

define

# Remediation statements for a specific NVIDIA XID code (xid_error -> resolved_by -> action).
fun fixes_for_xid($code: integer) -> { statement }:
  match
    $x isa xid_error, has xid_code $c; $c == $code;
    (symptom: $x, remedy: $a) isa resolved_by;
    $a has statement $s;
  return { $s };

# XID codes that can occur on a given GPU model (xid_error -> applies_to -> gpu_model).
fun xids_for_gpu_model($model: string) -> { xid_code }:
  match
    $x isa xid_error; $g isa gpu_model, has name $n; $n == $model;
    (fault: $x, model: $g) isa applies_to;
    $x has xid_code $code;
  return { $code };

# Remediation statements for a root-cause family (root_cause[subtype] <- indicates <-
# symptom -> resolved_by -> action). Works for any family: the curated failure modes,
# the Run:ai built-in alerts, and the XID GPU faults all attach here.
fun fixes_for_family($fam: string) -> { statement }:
  match
    $rc isa root_cause, has subtype $sub; $sub == $fam;
    (symptom: $sy, cause: $rc) isa indicates;
    (symptom: $sy, remedy: $a) isa resolved_by;
    $a has statement $s;
  return { $s };

# Root-cause XIDs for an observed XID: which faults lead_to (escalate into) the
# given code, one hop back along the leads_to causal chain. When the evidence
# shows Xid 45 or 154, this answers "the likely ROOT faults are these".
fun root_xids_for($code: integer) -> { xid_code }:
  match
    $e isa xid_error, has xid_code $c; $c == $code;
    (cause_fault: $r, effect_fault: $e) isa leads_to;
    $r has xid_code $root;
  return { $root };

# Generic family candidates for a normalized current symptom. The agent invokes
# this once per LIVE matched symptom and aggregates the returned families in
# Python: TypeDB lists are not available as function arguments yet.
fun causes_for_symptom($symptom_name: string) -> { subtype }:
  match
    $s isa symptom, has name $name; $name == $symptom_name;
    (symptom: $s, cause: $rc) isa indicates;
    $rc has subtype $subtype;
  return { $subtype };

# Approved historical RCA examples for synthesis. These are priors only: their
# evidence must never count as current-incident evidence or force confidence.
fun approved_incidents_for_cause($family: string) -> { incident_id, analysis_summary }:
  match
    $i isa incident, has incident_id $incident_id, has analysis_summary $analysis_summary,
      has approved_at $approved_at;
    $diagnosis isa diagnosis, links (run: $run, incident: $i, cause: $cause), has diagnosis_state "supported";
    $cause has subtype $subtype; $subtype == $family;
  return { $incident_id, $analysis_summary };

# Concrete evidence which supported an approved historical diagnosis.
fun evidence_for_approved_cause($family: string) -> { evidence_id, source, summary }:
  match
    $i isa incident, has approved_at $approved_at;
    $diagnosis isa diagnosis, links (run: $run, incident: $i, cause: $cause), has diagnosis_state "supported";
    $cause has subtype $subtype; $subtype == $family;
    $support isa supported_by, links (claim: $diagnosis, proof: $e);
    $e isa evidence, has evidence_id $evidence_id, has source $source, has summary $summary;
  return { $evidence_id, $source, $summary };

# Only operator-confirmed effective actions are returned here. Curated actions
# remain available through fixes_for_family and are labelled as such by synthesis.
fun verified_actions_for_family($family: string) -> { statement }:
  match
    $i isa incident, has approved_at $approved_at;
    $diagnosis isa diagnosis, links (run: $run, incident: $i, cause: $cause), has diagnosis_state "supported";
    $cause has subtype $subtype; $subtype == $family;
    $resolution isa resolution, links (finding: $diagnosis, remedy: $action), has outcome $outcome;
    { $outcome == "resolved"; } or { $outcome == "mitigated"; };
    $action has statement $statement;
  return { $statement };

# Internal recursive dependency traversal. It is cycle-safe because each call
# only returns existing component concepts and TypeDB evaluates to a fixed point.
fun _dependencies($component: control_plane_component) -> { control_plane_component }:
  match
    {
      (dependent: $component, dependency: $dependency) isa depends_on;
    } or {
      (dependent: $component, dependency: $next) isa depends_on;
      let $dependency in _dependencies($next);
    };
  return { $dependency };

fun dependencies_for_component($component_name: string) -> { name }:
  match
    $component isa control_plane_component, has name $name; $name == $component_name;
    let $dependency in _dependencies($component);
    $dependency has name $dependency_name;
  return { $dependency_name };

fun _dependents($component: control_plane_component) -> { control_plane_component }:
  match
    {
      (dependent: $dependent, dependency: $component) isa depends_on;
    } or {
      (dependent: $next, dependency: $component) isa depends_on;
      let $dependent in _dependents($next);
    };
  return { $dependent };

fun dependents_for_component($component_name: string) -> { name }:
  match
    $component isa control_plane_component, has name $name; $name == $component_name;
    let $dependent in _dependents($component);
    $dependent has name $dependent_name;
  return { $dependent_name };

fun checks_for_component_path($component_name: string) -> { name, check_command }:
  match
    $component isa control_plane_component, has name $name; $name == $component_name;
    { $target is $component; } or { let $target in _dependencies($component); };
    $target has name $target_name, has check_command $check_command;
  return { $target_name, $check_command };

fun affected_workloads_for_node($node_name: string) -> { name }:
  match
    $node isa node, has name $name; $name == $node_name;
    (host: $node, guest: $pod) isa runs_on;
    (owner: $workload, member: $pod) isa belongs_to;
    $workload has name $workload_name;
  return { $workload_name };

fun ancestor_xids_for($code: integer) -> { xid_code }:
  match
    $effect isa xid_error, has xid_code $effect_code; $effect_code == $code;
    {
      (cause_fault: $ancestor, effect_fault: $effect) isa leads_to;
    } or {
      (cause_fault: $next, effect_fault: $effect) isa leads_to;
      $next has xid_code $next_code;
      let $ancestor_code in ancestor_xids_for($next_code);
      $ancestor isa xid_error, has xid_code $ancestor_code;
    };
    $ancestor has xid_code $xid_code;
  return { $xid_code };

# Run:AI RCA ontology — TypeDB 3.x reasoning FUNCTIONS.
#
# TypeDB 3.0 replaced 2.x `rule ... when {} then {}` reasoning with FUNCTIONS
# (`define fun`): query-time derivation, invoked explicitly from a match with
# `let $x in fn(...)`. These give the knowledge graph real reasoning power
# (what the earlier PoC deferred as "complex").
#
# Loaded AFTER the schema by ontology/load_functions.py — as a SEPARATE define so
# a function issue on a future TypeDB patch can never break the core schema/data
# load. VALIDATED against TypeDB CE 3.11.5 on 2026-07-10, including the
# executable diagnostic runbook functions below. Original function examples:
#   fixes_for_xid(79)                    -> "Reset the GPU / contact support."
#   xids_for_gpu_model("H100")           -> 79
#   fixes_for_family("gpu_hardware_error") -> "Reset the GPU / contact support."

define

# Remediation statements for a specific NVIDIA XID code (xid_error -> resolved_by -> action).
fun fixes_for_xid($code: integer) -> { statement }:
  match
    $x isa xid_error, has xid_code $c; $c == $code;
    (symptom: $x, remedy: $a) isa resolved_by;
    $a has statement $s;
  return { $s };

# NVIDIA diagnostic guidance authored for a specific XID code.
fun trigger_for_xid($code: integer) -> { xid_trigger }:
  match
    $x isa xid_error, has xid_code $c, has xid_trigger $trigger; $c == $code;
  return { $trigger };

# XID codes that can occur on a given GPU model (xid_error -> applies_to -> gpu_model).
fun xids_for_gpu_model($model: string) -> { xid_code }:
  match
    $x isa xid_error; $g isa gpu_model, has name $n; $n == $model;
    (fault: $x, model: $g) isa applies_to;
    $x has xid_code $code;
  return { $code };

# Diagnostic aggregation of statements beneath a root-cause family. This loses
# the symptom identity and therefore MUST NOT select executable incident actions;
# production remediation uses the symptom -> resolved_by -> action relation.
# Retained for ontology inspection/backward compatibility only.
fun fixes_for_family($fam: string) -> { statement }:
  match
    $rc isa root_cause, has subtype $sub; $sub == $fam;
    (symptom: $sy, cause: $rc) isa indicates;
    (symptom: $sy, remedy: $a) isa resolved_by;
    $a has statement $s;
  return { $s };

# Root-cause XIDs for an observed XID: which faults lead_to (escalate into) the
# given code, one hop back along the leads_to causal chain. When the evidence
# shows Xid 45 or 154, this answers "the likely ROOT faults are these".
fun root_xids_for($code: integer) -> { xid_code }:
  match
    $e isa xid_error, has xid_code $c; $c == $code;
    (cause_fault: $r, effect_fault: $e) isa leads_to;
    $r has xid_code $root;
  return { $root };

# Generic family candidates for a normalized current symptom. The agent invokes
# this once per LIVE matched symptom and aggregates the returned families in
# Python: TypeDB lists are not available as function arguments yet.
fun causes_for_symptom($symptom_name: string) -> { subtype }:
  match
    $s isa symptom, has name $name; $name == $symptom_name;
    (symptom: $s, cause: $rc) isa indicates;
    $rc has subtype $subtype;
  return { $subtype };

# Approved historical RCA examples for synthesis. These are priors only: their
# evidence must never count as current-incident evidence or force confidence.
fun approved_incidents_for_cause($family: string) -> { incident_id, analysis_summary }:
  match
    $i isa incident, has incident_id $incident_id, has analysis_summary $analysis_summary,
      has status "resolved";
    $case isa case_snapshot, has approval_state "active";
    $i isa incident, has status "resolved";
    $diagnosis isa diagnosis, links (run: $run, incident: $i, cause: $cause), has diagnosis_state "supported";
    (case: $case, finding: $diagnosis) isa case_projection;
    $cause has subtype $subtype; $subtype == $family;
  return { $incident_id, $analysis_summary };

# Concrete evidence which supported an approved historical diagnosis.
fun evidence_for_approved_cause($family: string) -> { evidence_id, source, summary }:
  match
    $case isa case_snapshot, has approval_state "active";
    $i isa incident, has status "resolved";
    $diagnosis isa diagnosis, links (run: $run, incident: $i, cause: $cause), has diagnosis_state "supported";
    (case: $case, finding: $diagnosis) isa case_projection;
    $cause has subtype $subtype; $subtype == $family;
    $support isa supported_by, links (claim: $diagnosis, proof: $e);
    $e isa evidence, has evidence_id $evidence_id, has source $source, has summary $summary;
  return { $evidence_id, $source, $summary };

# Immutable, approval-bound CaseCard payload. It is a historical prior only;
# callers must still collect current-incident evidence before asserting an RCA.
fun approved_case_card($case_id: string) -> { case_card }:
  match
    $case isa case_snapshot, has case_id $id, has approval_state "active", has case_card $card;
    $id == $case_id;
  return { $card };

# Historical diagnosis-level aggregation for ontology inspection only. It has no
# symptom identity and MUST NOT select current-incident actions. Approved actions
# become executable knowledge only after promotion creates confirmed:<alert_name>
# as a symptom and links that symptom to the action via resolved_by.
fun verified_actions_for_family($family: string) -> { statement }:
  match
    $case isa case_snapshot, has approval_state "active";
    $diagnosis isa diagnosis, links (run: $run, incident: $i, cause: $cause), has diagnosis_state "supported";
    (case: $case, finding: $diagnosis) isa case_projection;
    $cause has subtype $subtype; $subtype == $family;
    $resolution isa resolution, links (finding: $diagnosis, remedy: $action), has outcome $outcome;
    { $outcome == "resolved"; } or { $outcome == "mitigated"; };
    $action has statement $statement;
  return { $statement };

# Internal recursive dependency traversal. It is cycle-safe because each call
# only returns existing component concepts and TypeDB evaluates to a fixed point.
fun _dependencies($component: control_plane_component) -> { control_plane_component }:
  match
    {
      (dependent: $component, dependency: $dependency) isa depends_on;
    } or {
      (dependent: $component, dependency: $next) isa depends_on;
      let $dependency in _dependencies($next);
    };
  return { $dependency };

fun dependencies_for_component($component_name: string) -> { name }:
  match
    $component isa control_plane_component, has name $name; $name == $component_name;
    let $dependency in _dependencies($component);
    $dependency has name $dependency_name;
  return { $dependency_name };

fun _dependents($component: control_plane_component) -> { control_plane_component }:
  match
    {
      (dependent: $dependent, dependency: $component) isa depends_on;
    } or {
      (dependent: $next, dependency: $component) isa depends_on;
      let $dependent in _dependents($next);
    };
  return { $dependent };

fun dependents_for_component($component_name: string) -> { name }:
  match
    $component isa control_plane_component, has name $name; $name == $component_name;
    let $dependent in _dependents($component);
    $dependent has name $dependent_name;
  return { $dependent_name };

fun checks_for_component_path($component_name: string) -> { name, check_command }:
  match
    $component isa control_plane_component, has name $name; $name == $component_name;
    { $target is $component; } or { let $target in _dependencies($component); };
    $target has name $target_name, has check_command $check_command;
  return { $target_name, $check_command };

fun affected_workloads_for_node($node_name: string) -> { name }:
  match
    $node isa node, has name $name; $name == $node_name;
    (host: $node, guest: $pod) isa runs_on;
    (owner: $workload, member: $pod) isa belongs_to;
    $workload has name $workload_name;
  return { $workload_name };

# All executable steps in a runbook. The loader materializes empty strings for
# optional prose fields so every row has a stable tuple shape for the agent.
fun diagnostic_steps_for_runbook($runbook: string) -> {
  diagnostic_id, question, verification, interpretation, avoidance, match_expression
}:
  match
    $r isa runbook, has name $rn; $rn == $runbook;
    (runbook: $r, step: $s) isa runbook_contains;
    $s has diagnostic_id $id,
       has question $q,
       has verification $v,
       has interpretation $i,
       has avoidance $a,
       has match_expression $m;
  return { $id, $q, $v, $i, $a, $m };

# Structured, read-only probe templates. They are authored in the YAML seed,
# validated by the loader, and projected to all reasoning agents through the
# same TypeDB runbook path as questions and disconfirmations.
fun diagnostic_probes_for_runbook($runbook: string) -> { diagnostic_id, probe_template }:
  match
    $r isa runbook, has name $rn; $rn == $runbook;
    (runbook: $r, step: $s) isa runbook_contains;
    $s has diagnostic_id $id, has probe_template $probe;
  return { $id, $probe };

# Entry point(s) for an executable runbook.
fun entry_steps_for_runbook($runbook: string) -> { diagnostic_id }:
  match
    $r isa runbook, has name $rn; $rn == $runbook;
    (runbook: $r, step: $s) isa runbook_entry;
    $s has diagnostic_id $id;
  return { $id };

# Ordered outgoing transitions from one diagnostic step. The application sorts
# the returned priority because TypeDB functions intentionally return sets.
fun next_diagnostic_steps($step: string) -> {
  diagnostic_id, match_expression, transition_priority
}:
  match
    $s isa diagnostic_step, has diagnostic_id $sid; $sid == $step;
    (prior: $s, next: $n) isa diagnostic_transition,
      has match_expression $m,
      has transition_priority $p;
    $n has diagnostic_id $nid;
  return { $nid, $m, $p };

# Root-cause outcome attached to a terminal diagnostic step.
fun diagnostic_outcomes_for($step: string) -> { subtype, summary, confidence }:
  match
    $s isa diagnostic_step, has diagnostic_id $sid; $sid == $step;
    $o isa diagnostic_outcome(step: $s, cause: $c),
      has summary $sum,
      has confidence $conf;
    $c has subtype $family;
  return { $family, $sum, $conf };

# Ordered remediation statements for a terminal diagnostic step.
fun diagnostic_actions_for($step: string) -> { statement, sequence_index }:
  match
    $s isa diagnostic_step, has diagnostic_id $sid; $sid == $step;
    (step: $s, remedy: $a) isa diagnostic_recommendation,
      has sequence_index $seq;
    $a has statement $st;
  return { $st, $seq };

# Evidence that should refute or weaken a terminal outcome.
fun diagnostic_disconfirmations_for($step: string) -> { disconfirm }:
  match
    $s isa diagnostic_step, has diagnostic_id $sid; $sid == $step;
    (step: $s, cause: $c) isa diagnostic_outcome, has disconfirm $d;
  return { $d };

# Reverse lookup used by planners/collectors: which diagnostic steps can lead
# to a given root-cause family?
fun diagnostic_steps_for_family($fam: string) -> { diagnostic_id }:
  match
    $c isa root_cause, has subtype $family; $family == $fam;
    (step: $s, cause: $c) isa diagnostic_outcome;
    $s has diagnostic_id $id;
  return { $id };

# Bulk graph projections used by the runtime. They avoid issuing one query per
# step while preserving the same typed relations as the per-step functions.
fun diagnostic_transitions_for_runbook($runbook: string) -> {
  diagnostic_id, diagnostic_id, match_expression, transition_priority
}:
  match
    $r isa runbook, has name $rn; $rn == $runbook;
    (runbook: $r, step: $p) isa runbook_contains;
    (prior: $p, next: $n) isa diagnostic_transition,
      has match_expression $m,
      has transition_priority $priority;
    $p has diagnostic_id $pid;
    $n has diagnostic_id $nid;
  return { $pid, $nid, $m, $priority };

fun diagnostic_outcomes_for_runbook($runbook: string) -> {
  diagnostic_id, subtype, summary, confidence
}:
  match
    $r isa runbook, has name $rn; $rn == $runbook;
    (runbook: $r, step: $s) isa runbook_contains;
    (step: $s, cause: $c) isa diagnostic_outcome,
      has summary $sum,
      has confidence $conf;
    $s has diagnostic_id $id;
    $c has subtype $family;
  return { $id, $family, $sum, $conf };

fun diagnostic_actions_for_runbook($runbook: string) -> {
  diagnostic_id, statement, sequence_index
}:
  match
    $r isa runbook, has name $rn; $rn == $runbook;
    (runbook: $r, step: $s) isa runbook_contains;
    (step: $s, remedy: $a) isa diagnostic_recommendation,
      has sequence_index $seq;
    $s has diagnostic_id $id;
    $a has statement $st;
  return { $id, $st, $seq };

fun diagnostic_disconfirmations_for_runbook($runbook: string) -> {
  diagnostic_id, disconfirm
}:
  match
    $r isa runbook, has name $rn; $rn == $runbook;
    (runbook: $r, step: $s) isa runbook_contains;
    (step: $s, cause: $c) isa diagnostic_outcome, has disconfirm $d;
    $s has diagnostic_id $id;
  return { $id, $d };

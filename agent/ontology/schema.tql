# Run:AI RCA ontology — TypeDB 3.x (TypeQL).
#
# The durable, store-independent model behind the RCA knowledge graph: typed
# entities + relations + a root_cause taxonomy (5 families as sub-types).
# Apply with:  python -m ontology.load_schema   (see agent/ontology/load_schema.py)
#
# ponytail: GPU capacity/demand are attributes on node/queue/project, not a
# first-class `gpu` entity. Promote to an entity only if per-GPU facts are needed.

define

# --- attributes -------------------------------------------------------------
attribute name, value string;
attribute incident_id, value string;
attribute alert_id, value string;
attribute run_id, value string;
attribute correlation_key, value string;
attribute analysis_summary, value string;
attribute title, value string;
attribute severity, value string;
attribute status, value string;
attribute alert_name, value string;
attribute fingerprint, value string;
attribute occurrence_count, value integer;
attribute reason, value string;
attribute reason_ko, value string;
attribute name_ko, value string;
attribute component, value string;
attribute condition_type, value string;
attribute keyword, value string;
attribute workload_type, value string;
attribute workload_id, value string;
attribute gpu_allocated, value double;
attribute gpu_requested, value double;
attribute source, value string;
attribute summary, value string;
attribute confidence, value string;
attribute blast_radius, value string;
attribute subtype, value string;
attribute statement, value string;
attribute statement_ko, value string;
attribute exclusive_actions, value boolean;
attribute created_at, value datetime;
# --- XID GPU-error catalog attributes ---
attribute xid_code, value integer;
attribute xid_trigger, value string;
attribute mnemonic, value string;
attribute description, value string;
# --- platform-architecture attributes (control_plane_component) ---
attribute layer, value string;           # cluster | control_plane | external
attribute k8s_namespace, value string;
attribute failure_effect, value string;
attribute owns_schema, value string;     # control-plane Postgres schema this service owns
attribute check_command, value string;   # ready-to-run operator check
# --- Run:ai known-issues catalog attributes (version-linked issues) ---
attribute affected_version, value string;
attribute fixed_version, value string;
# --- RCA harness / approved-history attributes ---
attribute evidence_id, value string;
attribute evidence_type, value string;
attribute artifact_ref, value string;
attribute analysis_hash, value string;
attribute diagnosis_state, value string;
attribute harness_status, value string;
attribute harness_score, value integer;
attribute approved_at, value string;
attribute outcome, value string;
attribute case_id, value string;
attribute approval_state, value string;
attribute cause_id, value string;
attribute mechanism, value string;
attribute mechanism_fingerprint, value string;
attribute case_card, value string;
attribute quality_score, value integer;
# --- executable diagnostic runbooks ---------------------------------------
attribute diagnostic_id, value string;
attribute runbook_name, value string;
attribute question, value string;
attribute verification, value string;
attribute interpretation, value string;
attribute avoidance, value string;
attribute match_expression, value string;
attribute transition_priority, value integer;
attribute sequence_index, value integer;
attribute source_url, value string;
attribute principle, value string;
attribute disconfirm, value string;
attribute probe_template, value string;
# --- incident-derived diagnostic trace (v3) -------------------------------
# These are deliberately separate from the legacy `probe_template` JSON. The
# JSON remains the runtime compatibility contract; these attributes make the
# authored templates and an approved incident's explicit trace queryable.
attribute hypothesis_id, value string;
attribute hypothesis_family, value string;
attribute hypothesis_status, value string;
attribute probe_id, value string;
attribute probe_tool, value string;
attribute probe_execution_id, value string;
attribute probe_verdict, value string;
attribute trace_version, value integer;
attribute trace_local_id, value string;
attribute observed_entity, value string;
attribute source_group, value string;
attribute predicate, value string;
attribute observed_value, value string;
attribute polarity, value string;
attribute coverage, value string;
attribute observed_window_start, value string;
attribute observed_window_end, value string;
attribute quality, value string;
attribute executed_at, value string;
attribute rejection_reason, value string;
attribute package_id, value string;
attribute package_status, value string;
attribute package_published_at, value string;
attribute package_retired_at, value string;
attribute package_template_binding_id, value string;
attribute template_active, value boolean;

# --- entities ---------------------------------------------------------------
entity cluster,
    owns name @key,
    plays scopes:scope;

entity node,
    owns name @key,
    owns condition_type,
    owns gpu_allocated,
    plays runs_on:host,
    plays scopes:member;

entity namespace,
    owns name @key,
    plays contains:space;

entity project,
    owns name @key,
    owns gpu_allocated,
    owns gpu_requested,
    plays in_project:project,
    plays scopes:member;

entity queue,
    owns name @key,
    owns gpu_allocated,
    owns gpu_requested,
    plays submitted_to:queue;

entity workload,
    owns name,
    owns workload_type,
    owns workload_id,
    plays belongs_to:owner,
    plays in_project:member,
    plays submitted_to:job,
    plays contains:occupant;

entity pod,
    owns name,
    owns status,
    plays runs_on:guest,
    plays belongs_to:member,
    plays contains:occupant;

# Run:ai platform components (BOTH the cluster side and the runai-backend
# control plane; `layer` disambiguates). Mirrored from
# knowledge/runai_architecture.yaml by ontology/load_architecture.py: purpose
# (description), failure effect, dependency edges, control-plane DB schema
# ownership, and ready-to-run checks.
entity control_plane_component,
    owns name,
    owns layer,
    owns k8s_namespace,
    owns description,
    owns failure_effect,
    owns owns_schema,
    # A component ships several ready-to-run checks; without the explicit card
    # the 3.x default @card(0..1) makes any 2-check component uncommittable.
    owns check_command @card(0..),
    plays emits:emitter,
    plays contains:occupant,
    plays depends_on:dependent,
    plays depends_on:dependency;

entity alert,
    owns alert_id @key,
    owns alert_name,
    owns fingerprint,
    owns severity,
    owns status,
    owns occurrence_count,
    owns reason,
    plays grouped_into:member;

entity incident,
    owns incident_id @key,
    owns correlation_key,
    owns analysis_summary,
    owns title,
    owns severity,
    owns status,
    owns created_at,
    owns approved_at,
    plays grouped_into:incident,
    plays has_symptom:incident,
    plays analyzed_by:incident,
    plays diagnosis:incident,
    plays hypothesis_for:incident;

entity analysis_run,
    owns run_id @key,
    owns source,
    owns status,
    owns confidence,
    plays analyzed_by:run,
    plays diagnosis:run,
    plays hypothesis_for:run;

entity symptom,
    owns name,
    owns reason,
    owns reason_ko @card(0..1),
    owns name_ko @card(0..1),
    owns component @card(0..1),
    owns exclusive_actions @card(0..1),
    owns condition_type,
    # A symptom matches on many keywords. TypeDB 3.x defaults ownership to
    # @card(0..1), so this MUST be explicit or multi-keyword insert fails at
    # commit ([CNT5] @card(0..1) violated).
    owns keyword @card(0..),
    owns statement_ko @card(0..),
    # Version-linked known issues (knowledge/runai_known_issues.yaml). Optional:
    # most symptoms carry no version. @card(0..1) is the 3.x default, stated for
    # clarity alongside the multi-valued keyword above.
    owns affected_version @card(0..1),
    owns fixed_version @card(0..1),
    plays has_symptom:symptom,
    plays indicates:symptom,
    plays resolved_by:symptom,
    plays supported_by:claim,
    plays emits:signal;

entity root_cause,
    owns subtype,
    owns confidence,
    owns blast_radius,
    owns statement,
    plays indicates:cause,
    plays supported_by:claim,
    plays diagnosis:cause,
    plays diagnostic_outcome:cause;

# A run-specific, open-world mechanism. Unlike the fixed catalog family types,
# this is an entity with a stable data key, so a novel mechanism is never
# coerced into insufficient_evidence simply because it lacks a schema subtype.
entity cause_instance sub root_cause,
    owns cause_id @key,
    owns mechanism,
    owns mechanism_fingerprint;

entity case_snapshot,
    owns case_id @key,
    owns approval_state,
    owns approved_at,
    owns analysis_hash,
    owns mechanism,
    owns mechanism_fingerprint,
    owns case_card,
    owns quality_score,
    plays case_projection:case;

# root-cause taxonomy — families as sub-types (see knowledge/troubleshooting_cases.md)
entity node_kubelet_pressure sub root_cause;
entity runai_scheduling_quota sub root_cause;
entity k8s_scheduling_error sub root_cause;       # kube-scheduler predicates: taint/affinity/topology/resourcequota
entity runai_control_plane_error sub root_cause;  # Run:ai platform: runai-scheduler, runai-backend, cluster-sync
entity k8s_control_plane_error sub root_cause;     # Kubernetes cluster: apiserver, etcd, kube-scheduler, kubelet certs, webhooks
entity workload_startup_error sub root_cause;
entity image_pull_error sub root_cause;         # image/registry: pull, tag, auth, TLS, 5xx
entity insufficient_evidence sub root_cause;
# NVIDIA XID GPU hardware faults (see knowledge/xid_catalog.yaml).
entity gpu_hardware_error sub root_cause;
# Run:ai known-issue families (see knowledge/runai_known_issues.yaml):
#   platform_version_bug   = regression fixed by upgrading Run:ai to a fixed version
#   observability_accuracy = metrics/dashboard wrong while the cluster itself is fine
#   expected_known_behavior = by-design behavior or product limitation, NOT a fault
entity platform_version_bug sub root_cause;
entity observability_accuracy sub root_cause;
entity expected_known_behavior sub root_cause;
# Layer families widening the signature entry points (2026-07-03): real cases
# span more layers than the original four generic families could name.
entity network_fabric_error sub root_cause;    # NCCL/NVLink/IB/RDMA/Fabric Manager
entity cluster_network_error sub root_cause;   # CNI/CoreDNS/pod networking
entity k8s_storage_error sub root_cause;        # CSI/PVC/NFS/Ceph/disk-IO layer
entity storage_backend_error sub root_cause;   # backend storage health: NFS, Ceph, node filesystem
entity workload_runtime_error sub root_cause;  # running-phase app faults (vs startup)
entity platform_auth_error sub root_cause;     # login/permissions/SAML/OIDC/JWT, UI-API 401/403/503/500
# Nature axis (2026-07-09): a rollout/upgrade in progress is a lifecycle EVENT,
# not a fault — cycling pods during a controller rollout or Helm upgrade are
# expected disruption. Names the case an upgrade would otherwise be mis-blamed on.
entity platform_lifecycle_change sub root_cause;

entity action,
    owns statement,
    plays resolved_by:remedy,
    plays resolution:remedy,
    plays diagnostic_recommendation:remedy;

entity evidence,
    owns evidence_id @key,
    owns evidence_type,
    owns trace_local_id,
    owns artifact_ref,
    owns source,
    owns summary,
    owns confidence,
    # Trace-v3 evidence metadata is populated only from explicit trace fields;
    # legacy artifacts intentionally remain unannotated rather than guessed.
    owns observed_entity,
    owns source_group,
    owns predicate,
    owns observed_value,
    owns polarity,
    owns coverage,
    owns observed_window_start,
    owns observed_window_end,
    owns quality,
    plays supported_by:proof,
    plays emits:signal,
    plays contradicted_by:proof,
    plays probe_execution_evidence:proof,
    plays rejected_evidence_link:proof;

# A hypothesis is a run-local, incident-derived candidate. It is never seeded
# from historical/legacy data, and does not itself assert an RCA.
entity hypothesis,
    owns hypothesis_id @key,
    owns trace_local_id,
    owns hypothesis_family,
    owns hypothesis_status,
    owns confidence,
    owns mechanism,
    owns mechanism_fingerprint,
    owns trace_version,
    plays hypothesis_for:hypothesis,
    plays probe_execution_tests:hypothesis,
    plays supported_by:claim,
    plays contradicted_by:claim,
    plays rejected_evidence_link:hypothesis;

entity runbook,
    owns name @key,
    owns summary,
    owns source_url @card(0..),
    owns principle @card(0..),
    plays runbook_contains:runbook,
    plays runbook_entry:runbook;

entity diagnostic_step,
    owns diagnostic_id @key,
    owns runbook_name,
    owns question,
    owns verification,
    owns interpretation,
    owns avoidance,
    owns match_expression,
    owns probe_template @card(0..),
    plays runbook_contains:step,
    plays runbook_entry:step,
    plays diagnostic_transition:prior,
    plays diagnostic_transition:next,
    plays diagnostic_outcome:step,
    plays diagnostic_recommendation:step,
    plays probe_template_for:step;

# Stable IDs are authored in k8s_troubleshooting_tree.yaml. The loader also
# keeps the complete canonical template for consumers that cannot interpret the
# legacy JSON attribute on diagnostic_step.
entity diagnostic_probe_template,
    owns probe_id @key,
    owns probe_tool,
    plays probe_template_for:template,
    plays probe_execution_for:template,
    plays package_has_template:template;

# Package mirroring is asynchronous and advisory: runtime activation reads the
# backend package lifecycle, never this TypeDB projection.
entity knowledge_package,
    owns package_id @key,
    owns package_status,
    owns case_id,
    owns title,
    owns summary,
    owns hypothesis_family,
    owns package_published_at,
    owns package_retired_at,
    plays package_has_template:package;

entity package_template_binding,
    owns package_template_binding_id @key,
    owns template_active,
    plays package_has_template:binding;

# A recorded execution exists only when an approved trace-v3 explicitly names
# both a stable template ID and its tested hypothesis. This prevents inferred
# links from legacy artifacts or prose.
entity probe_execution,
    owns probe_execution_id @key,
    owns trace_local_id,
    owns probe_verdict,
    owns trace_version,
    owns executed_at,
    plays probe_execution_for:execution,
    plays probe_execution_tests:execution,
    plays probe_execution_evidence:execution;

# --- relations --------------------------------------------------------------
relation scopes, relates scope, relates member;           # cluster scopes node/project
relation runs_on, relates host, relates guest;            # node runs_on pod
relation belongs_to, relates owner, relates member;       # workload belongs_to pod
relation in_project, relates project, relates member;     # project <- workload
relation submitted_to, relates queue, relates job;        # workload submitted_to queue
relation contains, relates space, relates occupant;       # namespace contains pod/workload/component
relation grouped_into, relates incident, relates member;  # incident <- alert
relation has_symptom, relates incident, relates symptom;
relation indicates, relates symptom, relates cause;       # symptom indicates root_cause
relation resolved_by, relates symptom, relates remedy;    # symptom resolved_by action (precise)
relation supported_by, relates claim, relates proof;      # (symptom|root_cause) <- evidence
relation contradicted_by, relates claim, relates proof;   # run-local diagnosis <- conflicting evidence
relation analyzed_by, relates incident, relates run;
relation emits, relates emitter, relates signal;          # component emits evidence/symptom
relation depends_on, relates dependent, relates dependency;  # component needs component (check order)
relation diagnosis,
    relates run,
    relates incident,
    relates cause,
    owns confidence,
    owns diagnosis_state,
    owns analysis_hash,
    owns harness_status,
    owns harness_score,
    plays supported_by:claim,
    plays contradicted_by:claim,
    plays case_projection:finding,
    plays resolution:finding;
relation resolution, relates finding, relates remedy, owns outcome;
relation case_projection, relates case, relates finding;

# Executable senior-SRE diagnostic graph. YAML is the version-controlled seed;
# ontology/load_troubleshooting.py mirrors it here for runtime traversal.
relation runbook_contains, relates runbook, relates step;
relation runbook_entry, relates runbook, relates step;
relation diagnostic_transition,
    relates prior,
    relates next,
    owns match_expression,
    owns transition_priority;
relation diagnostic_outcome,
    relates step,
    relates cause,
    owns summary,
    owns confidence,
    owns disconfirm @card(0..);
relation diagnostic_recommendation,
    relates step,
    relates remedy,
    owns sequence_index;

# Trace-v3's exact graph edges. Multiple hypotheses/evidence records attach to
# a single execution without inventing a cartesian-product relation.
relation hypothesis_for, relates run, relates incident, relates hypothesis;
relation probe_template_for, relates step, relates template;
relation probe_execution_for, relates execution, relates template;
relation probe_execution_tests, relates execution, relates hypothesis;
relation probe_execution_evidence, relates execution, relates proof;
relation rejected_evidence_link,
    relates hypothesis,
    relates proof,
    owns rejection_reason;
relation package_has_template, relates package, relates template, relates binding;

# --- XID GPU-error catalog ---------------------------------------------------
# A first-class GPU-hardware-fault RCA path. An xid_error is a catalog entry
# (one NVIDIA XID code); it applies_to the GPU models it can occur on, indicates
# the gpu_hardware_error root_cause family, and is resolved_by action(s). We
# reuse the existing `indicates`/`resolved_by`/`action` machinery so the
# knowledge layer stays uniform — xid_error slots in wherever a symptom does.
entity xid_error,
    owns xid_code @key,
    owns xid_trigger @card(0..1),
    owns mnemonic,
    owns description,
    owns severity,
    plays applies_to:fault,
    plays indicates:symptom,      # xid_error indicates gpu_hardware_error
    plays resolved_by:symptom,    # xid_error resolved_by action
    plays leads_to:cause_fault,   # this XID escalates to another XID...
    plays leads_to:effect_fault;  # ...and can itself be an escalation target

entity gpu_model,
    owns name @key,
    plays applies_to:model;

relation applies_to, relates fault, relates model;  # xid_error applies_to gpu_model

# Causal chain between XIDs: cause_fault escalates to / results in effect_fault
# (e.g. NVLink faults 144-146 lead to Xid 48/45/94/95; many faults report via 154).
# Edges come from xid_catalog.yaml `leads_to`, loaded by ontology/load_xids.py.
relation leads_to, relates cause_fault, relates effect_fault;

# --- inference (TypeDB 3.x) --------------------------------------------------
# NOTE: TypeDB 3.0 REMOVED the 2.x `rule <name>: when { } then { };` reasoning
# construct (it is replaced by `define fun` functions). A 2.x-style rule in this
# `define` would make the WHOLE schema fail to load on 3.11 — so there is none.
#
# The inference those rules would have derived is instead MATERIALIZED at load
# time by ontology/load_xids.py: it inserts an explicit `indicates` edge from
# every xid_error to the gpu_hardware_error root cause, plus `applies_to`
# (gpu_model) and `resolved_by` (action) edges. Severity + the resolved_by
# actions carry the fatal/escalation nuance (RESET_GPU / CONTACT_SUPPORT vs
# IGNORE), so no rule is needed to make XIDs first-class RCA candidates.
#
# If declarative, query-time reasoning is wanted later, add `define fun`
# functions here — that is the 3.x equivalent and needs live TypeDB validation.

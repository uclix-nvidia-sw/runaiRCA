{
  "openapi": "3.0.3",
  "info": {
    "title": "Run:ai RCA Backend API",
    "version": "0.1.56",
    "description": "Versioned HTTP contract for the Run:ai RCA Backend. Unless an operation states otherwise, successful responses use the envelope { \"status\": \"ok\", \"data\": ... } and list endpoints add a \"pagination\" block."
  },
  "servers": [{ "url": "/" }],
  "tags": [
    { "name": "Incidents" },
    { "name": "Alerts" },
    { "name": "Analysis" },
    { "name": "Knowledge" },
    { "name": "Operations" }
  ],
  "paths": {
    "/healthz": {
      "get": {
        "tags": ["Operations"],
        "summary": "Read backend health",
        "responses": {
          "200": {
            "description": "Healthy",
            "content": { "application/json": { "example": { "status": "ok" } } }
          }
        }
      }
    },
    "/webhook/alertmanager": {
      "post": {
        "tags": ["Alerts"],
        "summary": "Accept an Alertmanager webhook",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "example": {
                "version": "4",
                "status": "firing",
                "receiver": "runai-rca",
                "groupLabels": { "alertname": "KubePodCrashLooping" },
                "commonLabels": { "alertname": "KubePodCrashLooping", "namespace": "runai", "severity": "critical" },
                "alerts": [
                  {
                    "status": "firing",
                    "labels": { "alertname": "KubePodCrashLooping", "namespace": "runai", "pod": "gpu-operator-5b9c7d8f6-r2k4n", "severity": "critical" },
                    "annotations": { "summary": "Pod runai/gpu-operator is crash looping", "description": "Container has restarted 7 times in the last 10m" },
                    "startsAt": "2026-07-16T09:12:00Z",
                    "fingerprint": "a1b2c3d4e5f6a7b8"
                  }
                ]
              }
            }
          }
        },
        "responses": {
          "202": {
            "description": "Accepted for correlation and analysis",
            "content": { "application/json": { "example": { "status": "accepted", "incident_id": "inc_5f3a9c2b", "alert_id": "alr_9b1e4d7a" } } }
          },
          "400": { "$ref": "#/components/responses/Error" }
        }
      }
    },
    "/api/v1/incidents": {
      "get": {
        "tags": ["Incidents"],
        "summary": "List incidents",
        "parameters": [{ "$ref": "#/components/parameters/IncidentView" }],
        "responses": {
          "200": {
            "description": "Paginated list of incidents",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/Envelope" },
                "examples": { "incidents": { "$ref": "#/components/examples/IncidentListEnvelope" } }
              }
            }
          }
        }
      }
    },
    "/api/v1/incidents/bulk": {
      "post": {
        "tags": ["Incidents"],
        "summary": "Apply a lifecycle action to multiple incidents",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "required": ["incident_ids", "action"],
                "properties": {
                  "incident_ids": { "type": "array", "minItems": 1, "items": { "type": "string" } },
                  "action": { "type": "string", "enum": ["archive", "unarchive", "restore", "trash", "delete_permanently"] }
                }
              },
              "example": { "incident_ids": ["inc_5f3a9c2b", "inc_8d7e6f5a"], "action": "archive" }
            }
          }
        },
        "responses": {
          "200": { "description": "Lifecycle action applied", "content": { "application/json": { "example": { "status": "ok", "data": { "processed_ids": ["inc_5f3a9c2b", "inc_8d7e6f5a"] } } } } },
          "400": { "$ref": "#/components/responses/Error" }
        }
      }
    },
    "/api/v1/incidents/trash": {
      "delete": {
        "tags": ["Incidents"],
        "summary": "Permanently empty the incident trash",
        "responses": {
          "200": { "description": "All trashed incidents permanently deleted", "content": { "application/json": { "example": { "status": "ok", "data": { "deleted_count": 2 } } } } }
        }
      }
    },
    "/api/v1/incidents/{id}": {
      "get": {
        "tags": ["Incidents"],
        "summary": "Get an incident",
        "parameters": [{ "$ref": "#/components/parameters/ID" }],
        "responses": {
          "200": {
            "description": "Incident detail with the latest RCA",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/Envelope" },
                "examples": { "detail": { "$ref": "#/components/examples/IncidentDetailEnvelope" } }
              }
            }
          },
          "404": { "$ref": "#/components/responses/Error" }
        }
      },
      "delete": {
        "tags": ["Incidents"],
        "summary": "Trash or permanently delete an incident",
        "parameters": [
          { "$ref": "#/components/parameters/ID" },
          { "name": "permanent", "in": "query", "description": "When true, hard-delete instead of moving to trash.", "schema": { "type": "boolean", "default": false } }
        ],
        "responses": {
          "200": {
            "description": "Incident trashed or deleted",
            "content": { "application/json": { "example": { "status": "ok", "data": { "incident_id": "inc_5f3a9c2b", "deleted_at": "2026-07-16T10:30:00Z" } } } }
          },
          "404": { "$ref": "#/components/responses/Error" }
        }
      }
    },
    "/api/v1/incidents/{id}/analyze": {
      "post": {
        "tags": ["Analysis"],
        "summary": "Start an incident analysis",
        "parameters": [{ "$ref": "#/components/parameters/ID" }],
        "responses": {
          "202": {
            "description": "Analysis run accepted",
            "content": { "application/json": { "example": { "status": "ok", "data": { "run_id": "run_7c2d1a", "status": "running", "incident_id": "inc_5f3a9c2b" } } } }
          },
          "409": { "$ref": "#/components/responses/Error" }
        }
      }
    },
    "/api/v1/incidents/{id}/rca-correction": {
      "post": {
        "tags": ["Incidents"],
        "summary": "Record a pinned operator RCA correction",
        "parameters": [{ "$ref": "#/components/parameters/ID" }],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "example": {
                "root_cause_family": "gpu_hardware_error",
                "summary": "NVIDIA XID evidence identifies a failing GPU.",
                "actions": ["Drain the node", "Replace the GPU"]
              }
            }
          }
        },
        "responses": {
          "201": { "description": "Pinned operator analysis run created" },
          "400": { "$ref": "#/components/responses/Error" },
          "404": { "$ref": "#/components/responses/Error" },
          "503": { "$ref": "#/components/responses/Error" }
        }
      }
    },
    "/api/v1/incidents/{id}/rca-pin": {
      "post": {
        "tags": ["Incidents"],
        "summary": "Pin or unpin the latest operator RCA correction",
        "parameters": [{ "$ref": "#/components/parameters/ID" }],
        "requestBody": {
          "required": true,
          "content": { "application/json": { "example": { "pinned": false } } }
        },
        "responses": {
          "200": { "description": "Operator correction pin state updated" },
          "400": { "$ref": "#/components/responses/Error" },
          "404": { "$ref": "#/components/responses/Error" }
        }
      }
    },
    "/api/v1/incidents/{id}/reverify": {
      "post": {
        "tags": ["Analysis"],
        "summary": "Re-analyze using the pinned operator family as a leading hypothesis",
        "parameters": [{ "$ref": "#/components/parameters/ID" }],
        "responses": {
          "202": { "description": "Seeded re-verification analysis accepted" },
          "404": { "$ref": "#/components/responses/Error" },
          "409": { "$ref": "#/components/responses/Error" }
        }
      }
    },
    "/api/v1/incidents/{id}/resolve": {
      "post": {
        "tags": ["Incidents"],
        "summary": "Toggle operator RCA approval",
        "parameters": [{ "$ref": "#/components/parameters/ID" }],
        "responses": {
          "200": {
            "description": "Approval toggled",
            "content": { "application/json": { "example": { "status": "ok", "data": { "incident_id": "inc_5f3a9c2b", "user_approved_at": "2026-07-16T10:45:00Z" } } } }
          }
        }
      }
    },
    "/api/v1/incidents/{id}/{action}": {
      "post": {
        "tags": ["Incidents"],
        "summary": "Archive, unarchive, restore, vote, comment, or give feedback on an incident",
        "parameters": [
          { "$ref": "#/components/parameters/ID" },
          { "name": "action", "in": "path", "required": true, "schema": { "type": "string", "enum": ["archive", "unarchive", "restore", "vote", "comments", "feedback"] } }
        ],
        "requestBody": {
          "description": "Body depends on the action. Lifecycle actions (archive/unarchive/restore) take no body.",
          "content": {
            "application/json": {
              "examples": {
                "vote": { "summary": "vote", "value": { "vote": "up", "author": "on-call@example.com" } },
                "comments": { "summary": "comments", "value": { "body": "Confirmed GPU node NotReady; draining.", "author": "on-call@example.com" } },
                "feedback": { "summary": "feedback", "value": { "vote": "down", "comment": "Root cause was the CNI, not the scheduler.", "author": "on-call@example.com" } }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Feedback summary after applying the action",
            "content": { "application/json": { "examples": { "feedback": { "$ref": "#/components/examples/FeedbackSummaryEnvelope" } } } }
          },
          "404": { "$ref": "#/components/responses/Error" }
        }
      }
    },
    "/api/v1/alerts": {
      "get": {
        "tags": ["Alerts"],
        "summary": "List alerts",
        "responses": {
          "200": {
            "description": "Paginated list of alerts",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/Envelope" },
                "examples": { "alerts": { "$ref": "#/components/examples/AlertListEnvelope" } }
              }
            }
          }
        }
      }
    },
    "/api/v1/alerts/{id}": {
      "get": {
        "tags": ["Alerts"],
        "summary": "Get an alert",
        "parameters": [{ "$ref": "#/components/parameters/ID" }],
        "responses": {
          "200": {
            "description": "Alert detail",
            "content": { "application/json": { "examples": { "alert": { "$ref": "#/components/examples/AlertEnvelope" } } } }
          },
          "404": { "$ref": "#/components/responses/Error" }
        }
      }
    },
    "/api/v1/alerts/{id}/{action}": {
      "post": {
        "tags": ["Alerts"],
        "summary": "Vote, comment, or give feedback on an alert",
        "parameters": [
          { "$ref": "#/components/parameters/ID" },
          { "name": "action", "in": "path", "required": true, "schema": { "type": "string", "enum": ["vote", "comments", "feedback"] } }
        ],
        "requestBody": {
          "content": {
            "application/json": {
              "examples": {
                "vote": { "summary": "vote", "value": { "vote": "up", "author": "on-call@example.com" } },
                "comments": { "summary": "comments", "value": { "body": "Same fingerprint fired 5x in 10m.", "author": "on-call@example.com" } },
                "feedback": { "summary": "feedback", "value": { "vote": "down", "comment": "Noisy alert; threshold too low.", "author": "on-call@example.com" } }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Feedback summary after applying the action",
            "content": { "application/json": { "examples": { "feedback": { "$ref": "#/components/examples/FeedbackSummaryEnvelope" } } } }
          }
        }
      }
    },
    "/api/v1/embeddings/search": {
      "post": {
        "tags": ["Analysis"],
        "summary": "Search similar RCA memory",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": { "$ref": "#/components/schemas/EmbeddingSearchRequest" },
              "example": { "query": "gpu node NotReady after driver upgrade", "limit": 5 }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Ranked similar incidents",
            "content": {
              "application/json": {
                "example": {
                  "status": "ok",
                  "data": {
                    "model": "local-term-frequency",
                    "results": [
                      {
                        "incident_id": "inc_1a2b3c",
                        "title": "GPU node NotReady on driver mismatch",
                        "severity": "critical",
                        "status": "resolved",
                        "similarity": 0.82,
                        "analysis_summary": "nvidia-driver DaemonSet crashed after a kernel bump; node went NotReady.",
                        "positive_feedback": 3,
                        "negative_feedback": 0,
                        "comment_count": 2,
                        "created_at": "2026-07-02T14:03:00Z"
                      }
                    ]
                  }
                }
              }
            }
          },
          "400": { "$ref": "#/components/responses/Error" }
        }
      }
    },
    "/api/v1/analysis-runs": {
      "get": {
        "tags": ["Analysis"],
        "summary": "List analysis runs",
        "responses": {
          "200": {
            "description": "Paginated list of analysis runs",
            "content": { "application/json": { "examples": { "runs": { "$ref": "#/components/examples/AnalysisRunListEnvelope" } } } }
          }
        }
      }
    },
    "/api/v1/analysis-runs/{id}": {
      "get": {
        "tags": ["Analysis"],
        "summary": "Get an analysis run",
        "parameters": [{ "$ref": "#/components/parameters/ID" }],
        "responses": {
          "200": {
            "description": "Analysis run detail",
            "content": { "application/json": { "examples": { "run": { "$ref": "#/components/examples/AnalysisRunEnvelope" } } } }
          }
        }
      }
    },
    "/api/v1/analysis-runs/{id}/evaluation": {
      "get": {
        "tags": ["Analysis"],
        "summary": "Get an analysis evaluation",
        "parameters": [{ "$ref": "#/components/parameters/ID" }],
        "responses": {
          "200": {
            "description": "Evaluation view",
            "content": { "application/json": { "examples": { "evaluation": { "$ref": "#/components/examples/EvaluationEnvelope" } } } }
          }
        }
      },
      "put": {
        "tags": ["Analysis"],
        "summary": "Save an analysis evaluation",
        "parameters": [{ "$ref": "#/components/parameters/ID" }],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": { "$ref": "#/components/schemas/EvaluationReviewInput" },
              "example": {
                "analysis_hash": "sha256:9f2c…",
                "reviewer": "sre@example.com",
                "case_type": "known",
                "expected_family": "gpu_hardware_error",
                "scores": { "accuracy": 4, "actionability": 5 },
                "hard_gates": { "cited_evidence": true, "no_hallucinated_pods": true },
                "resolution_outcome": "resolved",
                "effective_action": "Cordoned node and replaced the GPU.",
                "notes": "Matched XID 79 signature."
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Saved review",
            "content": { "application/json": { "examples": { "review": { "$ref": "#/components/examples/EvaluationReviewEnvelope" } } } }
          }
        }
      }
    },
    "/api/v1/analysis-runs/{id}/progress": {
      "post": {
        "tags": ["Analysis"],
        "summary": "Append analysis progress",
        "parameters": [{ "$ref": "#/components/parameters/ID" }],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "example": { "phase": "collect", "collector": "kubernetes", "status": "running", "message": "Describing pod runai/gpu-operator…" }
            }
          }
        },
        "responses": {
          "202": {
            "description": "Progress appended",
            "content": { "application/json": { "example": { "status": "ok", "data": { "seq": 12, "phase": "collect", "collector": "kubernetes", "status": "running", "message": "Describing pod runai/gpu-operator…", "timestamp": "2026-07-16T09:14:03Z" } } } }
          }
        }
      }
    },
    "/api/v1/knowledge-candidates": {
      "get": {
        "tags": ["Knowledge"],
        "summary": "List knowledge candidates",
        "parameters": [{ "name": "status", "in": "query", "description": "Filter by lifecycle status (e.g. ready_for_review).", "schema": { "type": "string" } }],
        "responses": {
          "200": {
            "description": "Incident-derived knowledge candidates",
            "content": { "application/json": { "examples": { "candidates": { "$ref": "#/components/examples/KnowledgeCandidateListEnvelope" } } } }
          }
        }
      }
    },
    "/api/v1/knowledge-candidates/{id}": {
      "get": {
        "tags": ["Knowledge"],
        "summary": "Get a knowledge candidate",
        "parameters": [{ "$ref": "#/components/parameters/ID" }],
        "responses": {
          "200": {
            "description": "Candidate detail",
            "content": { "application/json": { "examples": { "candidate": { "$ref": "#/components/examples/KnowledgeCandidateEnvelope" } } } }
          },
          "404": { "$ref": "#/components/responses/Error" }
        }
      }
    },
    "/api/v1/knowledge-candidates/{id}/decision": {
      "post": {
        "tags": ["Knowledge"],
        "summary": "Approve, shadow, activate, or reject a candidate",
        "parameters": [{ "$ref": "#/components/parameters/ID" }],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": { "$ref": "#/components/schemas/KnowledgeDecision" },
              "example": { "action": "shadow", "actor": "on-call@example.com", "note": "Observe before activation." }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Candidate after the decision",
            "content": { "application/json": { "example": { "status": "ok", "data": { "candidate_id": "kc_44ab19", "status": "shadow", "decided_by": "on-call@example.com", "decided_at": "2026-07-16T11:02:00Z" } } } }
          },
          "400": { "$ref": "#/components/responses/Error" },
          "409": { "$ref": "#/components/responses/Error" },
          "422": { "$ref": "#/components/responses/Error" }
        }
      }
    },
    "/api/v1/knowledge-packages": {
      "get": {
        "tags": ["Knowledge"],
        "summary": "List knowledge packages",
        "parameters": [{ "name": "include_retired", "in": "query", "schema": { "type": "boolean", "default": false } }],
        "responses": {
          "200": {
            "description": "Active (and optionally retired) packages",
            "content": { "application/json": { "examples": { "packages": { "$ref": "#/components/examples/KnowledgePackageListEnvelope" } } } }
          }
        }
      }
    },
    "/api/v1/knowledge-packages/{id}": {
      "get": {
        "tags": ["Knowledge"],
        "summary": "Get a knowledge package",
        "parameters": [{ "$ref": "#/components/parameters/ID" }],
        "responses": {
          "200": {
            "description": "Package detail",
            "content": { "application/json": { "examples": { "package": { "$ref": "#/components/examples/KnowledgePackageEnvelope" } } } }
          },
          "404": { "$ref": "#/components/responses/Error" }
        }
      }
    },
    "/api/v1/knowledge-packages/{id}/retire": {
      "post": {
        "tags": ["Knowledge"],
        "summary": "Retire a knowledge package",
        "parameters": [{ "$ref": "#/components/parameters/ID" }],
        "requestBody": {
          "content": {
            "application/json": {
              "schema": { "$ref": "#/components/schemas/AuditNote" },
              "example": { "actor": "sre@example.com", "note": "Superseded by kp_77de02." }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Retired package",
            "content": { "application/json": { "example": { "status": "ok", "data": { "package_id": "kp_12ab34", "status": "retired", "retired_at": "2026-07-16T11:20:00Z" } } } }
          },
          "409": { "$ref": "#/components/responses/Error" }
        }
      }
    },
    "/api/v1/knowledge/runtime-snapshot": {
      "get": {
        "tags": ["Knowledge"],
        "summary": "Read the active runtime knowledge snapshot",
        "responses": {
          "200": {
            "description": "Active runtime snapshot",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/KnowledgeRuntimeSnapshot" },
                "example": { "revision": "rev_2026071601", "packages": [{ "package_id": "kp_12ab34", "root_cause_family": "gpu_hardware_error", "runtime_status": "active", "mirror_status": "synced" }] }
              }
            }
          },
          "304": { "description": "Not modified" }
        }
      }
    },
    "/api/v1/knowledge/probe-metrics": {
      "get": {
        "tags": ["Knowledge"],
        "summary": "Read aggregated trace-v3 probe metrics",
        "responses": {
          "200": {
            "description": "Probe utility metrics across approved cases",
            "content": {
              "application/json": {
                "example": {
                  "status": "ok",
                  "data": {
                    "case_count": 37,
                    "metrics": [
                      { "template_id": "probe.gpu.xid", "case_count": 12, "executions": 40, "supports": 28, "refutes": 6, "inconclusive": 6, "linked_evidence_count": 22, "linked_hypothesis_count": 10, "final_diagnosis_tests": 12, "final_diagnosis_supported": 11 }
                    ]
                  }
                }
              }
            }
          }
        }
      }
    },
    "/api/v1/knowledge/families": {
      "get": {
        "tags": ["Knowledge"],
        "summary": "List configured root-cause families",
        "responses": {
          "200": {
            "description": "Root-cause family catalog",
            "content": { "application/json": { "example": { "status": "ok", "data": { "families": ["gpu_hardware_error", "scheduler_preemption", "storage_csi_attach", "network_cni", "oom_kill"] } } } }
          },
          "503": { "$ref": "#/components/responses/Error" }
        }
      }
    },
    "/api/v1/stats/recurrence": {
      "get": {
        "tags": ["Operations"],
        "summary": "Read recurrence statistics",
        "parameters": [{ "$ref": "#/components/parameters/Days" }],
        "responses": {
          "200": {
            "description": "Recurrence rate over the window",
            "content": {
              "application/json": {
                "example": {
                  "status": "ok",
                  "data": {
                    "days": 7, "rate": 0.31, "total": 42, "recurred": 13,
                    "daily": [{ "date": "2026-07-16", "total": 6, "recurred": 2, "rate": 0.33 }]
                  }
                }
              }
            }
          }
        }
      }
    },
    "/api/v1/stats/llm-spend": {
      "get": {
        "tags": ["Operations"],
        "summary": "Read LLM spend statistics",
        "parameters": [{ "$ref": "#/components/parameters/Days" }],
        "responses": {
          "200": {
            "description": "LLM spend over the window",
            "content": {
              "application/json": {
                "example": {
                  "status": "ok",
                  "data": {
                    "days": 7, "calls": 318, "calls_without_usage": 4, "failed_calls": 2,
                    "prompt_tokens": 1204553, "completion_tokens": 210338, "total_tokens": 1414891, "cost_usd": 12.47,
                    "by_model": { "claude-opus-4-8": { "calls": 200, "calls_without_usage": 1, "failed_calls": 1, "prompt_tokens": 900000, "completion_tokens": 160000, "total_tokens": 1060000, "cost_usd": 10.10 } },
                    "daily": [{ "date": "2026-07-16", "calls": 45, "calls_without_usage": 0, "failed_calls": 0, "prompt_tokens": 170000, "completion_tokens": 30000, "total_tokens": 200000, "cost_usd": 1.80 }]
                  }
